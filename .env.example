# Global defaults
APP_TIMEZONE=Asia/Kolkata
LOG_LEVEL=INFO

# Service URLs (internal docker network)
GATEWAY_URL=http://gateway:8000
INGESTION_URL=http://ingestion:8020
SUMMARIZER_URL=http://summarizer:8030
NOTIFIER_URL=http://notifier:8040
AUTH_URL=http://auth:8050
SCAN_USER_ID=demo-user

# Microsoft identity / Graph (Office 365)
MS_TENANT_ID=common
MS_CLIENT_ID=replace-me
MS_CLIENT_SECRET=replace-me
MS_REDIRECT_URI=http://localhost:8000/api/mail/oauth/callback
MS_GRAPH_SCOPE=Mail.Read User.Read offline_access
ALLOW_SAMPLE_MAIL=false

# Persistence (local dev)
DATABASE_URL=sqlite:////data/email_summary.db

# AWS
AWS_REGION=ap-south-1
AWS_SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789012/email-summary-events
AWS_SECRETS_MANAGER_PREFIX=/email-summary
